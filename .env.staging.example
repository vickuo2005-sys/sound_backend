APP_ENV=staging
LOG_LEVEL=INFO

NODE_WEBSOCKET_ENABLED=true
COMMAND_WEBSOCKET_ENABLED=true
COMMAND_REST_FALLBACK_ENABLED=true

LIVE_AUDIO_ENABLED=false
LIVE_AUDIO_ALLOWED_CODECS=pcm_s16le
LIVE_AUDIO_DEFAULT_CODEC=pcm_s16le
LIVE_AUDIO_MAX_CONCURRENT_STREAMS=1
LIVE_AUDIO_MAX_SESSION_SECONDS=300
LIVE_AUDIO_RING_BUFFER_SECONDS=10

EVENT_UPLOAD_RETRY_ENABLED=true

DATABASE_URL=
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_MAPS_API_KEY=
UPLOAD_TOKEN=
DEVICE_TOKEN=
STREAM_TOKEN_SECRET=
DASHBOARD_AUTH_SECRET=
